# ============================================================================
#  Keeping Eyes on Your Agents - environment configuration
#  Copy this file to ".env" and fill in your values.
# ============================================================================

# ---- LLM (OpenAI) ----------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here

# Model used by the agents. gpt-4o-mini keeps the demo cheap & fast.
OPENAI_MODEL=gpt-4o-mini

# Model used by DeepEval LLM-as-a-judge metrics (TaskCompletion, PlanQuality...).
# A stronger judge gives more stable scores; gpt-4o is a good default.
DEEPEVAL_JUDGE_MODEL=gpt-4o

# OPTIONAL: route every OpenAI call through an AI gateway (e.g. Obot's LLM proxy,
# LiteLLM, Helicone...) so token usage + USD cost are tracked codelessly.
# Leave blank to call OpenAI directly. See docs/03_obot_gateway_guide.md.
# OPENAI_BASE_URL=http://localhost:8080/llm/v1

# ---- Token pricing (USD per 1M tokens) -------------------------------------
# Used to compute per-call cost on DeepEval LLM spans. Override per your model.
PRICE_INPUT_PER_M=0.15
PRICE_OUTPUT_PER_M=0.60

# ---- MCP connectivity ------------------------------------------------------
# Where the mock MCP servers listen (direct mode).
MCP_FLIGHTS_URL=http://localhost:8001/mcp
MCP_HOTELS_URL=http://localhost:8002/mcp
MCP_ACTIVITIES_URL=http://localhost:8003/mcp
MCP_BOOKING_URL=http://localhost:8004/mcp

# Set to "true" to route MCP traffic through the Obot MCP gateway instead of
# hitting the servers directly. When true, the *_URL values above are replaced
# by the gateway endpoints below (Layer 4 codeless observability).
USE_MCP_GATEWAY=false
MCP_GATEWAY_FLIGHTS_URL=http://localhost:8080/mcp/flights
MCP_GATEWAY_HOTELS_URL=http://localhost:8080/mcp/hotels
MCP_GATEWAY_ACTIVITIES_URL=http://localhost:8080/mcp/activities
MCP_GATEWAY_BOOKING_URL=http://localhost:8080/mcp/booking
# Optional bearer token the gateway expects (Obot brokers real upstream creds).
MCP_GATEWAY_TOKEN=

# ---- DeepEval (Layer 1/2 metrics) -----------------------------------------
# DeepEval metrics run fully locally with your OpenAI judge — no account needed.
# Confident AI (optional) was only a trace backend; we now use Langfuse instead.
# CONFIDENT_API_KEY=
CONFIDENT_TRACE_VERBOSE=0
CONFIDENT_TRACE_FLUSH=1

# ---- Langfuse (Layer 3 trace timeline — self-hosted, open source) ----------
# Docker Compose runs Langfuse locally and auto-provisions these keys on first
# boot, so nothing is required here. Override only if you point at a different
# Langfuse (e.g. Langfuse Cloud: set LANGFUSE_HOST=https://cloud.langfuse.com and
# your own keys). UI opens at http://localhost:3001 (admin@datahack.local /
# langfuse-demo). Set LANGFUSE_TRACING_ENABLED=false to turn tracing off.
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-datahack-public
LANGFUSE_SECRET_KEY=sk-lf-datahack-secret
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_URL=http://localhost:3001
LANGFUSE_PROJECT_ID=trip-planner

# ---- Demo controls ---------------------------------------------------------
# Set to "true" to inject the seeded tool-selection regression used in the
# live demo (Layer 1 catches it, Layer 2 localizes it). Set "false" to "fix".
INJECT_REGRESSION=false
